generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Voter {
  id           String   @id @default(uuid())
  name         String
  dob          String   // YYYY-MM-DD
  age          Int
  gender       String?
  address      String
  photoUrl     String
  photoVerifiedAt DateTime?
  faceVerificationEnabled Boolean @default(true)
  votingStatus String   @default("PENDING") // PENDING | IN_PROGRESS | VOTED | EXPIRED
  hasVoted     Boolean  @default(false)
  documentType String?
  createdAt    DateTime @default(now())

  tokens                Token[]
  auditLogs             AuditLog[]
  fingerprintTemplates  FingerprintTemplate[]
  documents             VoterDocument[]
}

model DocumentType {
  id           Int             @id @default(autoincrement())
  name         String          @unique // e.g. "Aadhaar Card", "PAN Card"
  documents    VoterDocument[]
}

model VoterDocument {
  id                  Int       @id @default(autoincrement())
  voterId             String
  voter               Voter     @relation(fields: [voterId], references: [id])
  documentTypeId      Int
  documentType        DocumentType @relation(fields: [documentTypeId], references: [id])
  documentTypeName    String?
  documentNumber      String
  nameOnDocument      String?
  issuingAuthority    String?
  issueDate           DateTime?
  expiryDate          DateTime?
  documentImage       Bytes?
  verificationStatus  String    @default("PENDING")
  verifiedAt          DateTime?
  remarks             String?

  @@unique([voterId, documentTypeId])
}

model Token {
  id               String    @id @default(uuid())
  code             String    @unique
  voterId          String
  voter            Voter     @relation(fields: [voterId], references: [id])
  verificationMode String    // "digital" | "manual"
  idType           String
  idNumber         String
  votingStatus     String    @default("TOKEN_ACTIVE") // TOKEN_ACTIVE | IN_PROGRESS | VOTED | EXPIRED
  generatedAt      DateTime  @default(now())
  expiresAt        DateTime
  verifiedAt       DateTime? // When TVO verified the token (set to IN_PROGRESS)
  confirmedAt      DateTime? // When TVO approved voting (set to VOTED)
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  terminal  String   // "digital" | "manual" | "tvo"
  action    String
  status    String   // "info" | "success" | "error" | "warning"
  details   String?
  voterId   String?
  voter     Voter?   @relation(fields: [voterId], references: [id])
  officerId String?
}

model Officer {
  id           String @id @default(uuid())
  officerId    String @unique
  name         String
  passwordHash String
  role         String @default("officer") // "officer" | "supervisor"
  boothId      String?
}

model Booth {
  id           String  @id @default(uuid())
  boothCode    String  @unique
  constituency String
  isOnline     Boolean @default(true)
}

// ─── Fingerprint Verification ──────────────────────────────────────────────

model FingerprintTemplate {
  id              String   @id @default(uuid())
  voterId         String
  voter           Voter    @relation(fields: [voterId], references: [id])
  fingerLabel     String   // LEFT_INDEX | RIGHT_INDEX | LEFT_THUMB | RIGHT_THUMB
  templateType    String   // extractor name e.g. "sourcefis"
  templateData    Bytes    // AES-GCM-256 encrypted template
  iv              String   // per-record encryption IV (hex)
  qualityScore    Float
  imageRef        String?  // optional audit image path
  templateVersion String   @default("sourcefis-v1")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model FingerprintLog {
  id                String   @id @default(uuid())
  sessionId         String
  voterId           String
  fingerLabel       String
  status            String   // SUCCESS | FAILED
  qualityScore      Float?
  matchScore        Float?
  threshold         Float
  failureReason     String?
  extractorUsed     String
  matchedTemplateId String?
  inputFormat       String?  // jpg | png
  templateVersion   String?
  deviceId          String?
  timestamp         DateTime @default(now())
}
