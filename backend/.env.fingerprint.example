# ─── Fingerprint Module Config ────────────────────────────────────────────────

# Match threshold (0–100 normalized score). 40 = strict for real biometric scans.
# Increase for more lenient matching, decrease for higher security.
FINGERPRINT_MATCH_THRESHOLD=40

# AES-GCM-256 encryption key for template storage.
# Must be exactly 64 hex characters (= 32 bytes / 256 bits).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FINGERPRINT_ENCRYPTION_KEY=change_this_to_a_64_hex_char_key_generated_with_crypto_randomBytes
